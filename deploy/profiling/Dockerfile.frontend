# Frontend — built from source with source maps + Splunk OTel profiling
#
# Source maps are enabled via next.config.js (config.devtool = 'source-map'
# for server, 'hidden-source-map' for client). This causes the pprof CPU
# profiler to report original TypeScript file paths in stack frames instead
# of compiled webpack bundle paths, enabling the profiling UI to show and
# fix real source code.
#
# Build context: opentelemetry-demo/ (repo root, one level up from deploy/)

# ── Stage 1: build Next.js with source maps + install @splunk/otel together ───
# Installing @splunk/otel in the same npm context as the frontend lets npm
# resolve any OTel version conflicts (prevents semconvStabilityFromStr errors).
FROM node:22-alpine AS next-builder
RUN apk add --no-cache libc6-compat
WORKDIR /app
COPY src/frontend/package*.json ./
RUN npm clean-install --no-audit --no-progress
# Install @splunk/otel alongside existing deps so versions resolve correctly
RUN npm install --no-save @splunk/otel
COPY src/frontend/protos ./protos
COPY src/frontend .
# Build — next.config.js sets devtool: 'source-map' for server chunks
RUN npm run build

# ── Stage 2: production runtime ───────────────────────────────────────────────
FROM node:22-alpine
WORKDIR /app
ENV NODE_ENV=production
# --enable-source-maps tells Node.js to resolve .js.map files at runtime so
# the pprof CPU profiler reports original TypeScript paths in stack frames.
ENV NODE_OPTIONS=--enable-source-maps

RUN addgroup -g 1001 -S nodejs && adduser -S nextjs -u 1001

COPY --from=next-builder /app/next.config.js ./
COPY --from=next-builder /app/public ./public
COPY --from=next-builder /app/package.json ./package.json

# Standalone Next.js output + source maps
COPY --from=next-builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=next-builder --chown=nextjs:nodejs /app/.next/static ./.next/static
COPY --from=next-builder --chown=nextjs:nodejs /app/.next/server ./.next/server

# node_modules with @splunk/otel already resolved alongside frontend deps
COPY --from=next-builder /app/node_modules ./node_modules

USER nextjs
ENV PORT=8080
EXPOSE ${PORT}

CMD ["node", "--require=@splunk/otel/instrument", "server.js"]
