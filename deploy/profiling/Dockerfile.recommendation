# Recommendation — Python 3.14 with Splunk OTel distro for AlwaysOn Profiling
#
# pip is present in the venv, so no multi-stage build is needed.
# We install splunk-opentelemetry[all] which adds CPU profiling support,
# then set OTEL_PYTHON_CONFIGURATOR so the existing opentelemetry-instrument
# entrypoint uses the Splunk configurator (no CMD change required).

FROM ghcr.io/open-telemetry/demo:latest-recommendation

# Install Splunk OTel Python distro into the existing venv
RUN /venv/bin/pip install --no-cache-dir "splunk-opentelemetry[all]"

# Bootstrap installs any missing auto-instrumentation libraries
RUN /venv/bin/splunk-py-trace-bootstrap || true

# Both opentelemetry-distro and splunk-opentelemetry register entry points
# with name "configurator". _load_configurators() only runs the FIRST match,
# which is opentelemetry.distro:OpenTelemetryConfigurator (comes first alphabetically).
# Rename OpenTelemetryConfigurator's entry so SplunkConfigurator is the sole match.
# The package remains installed (SplunkConfigurator imports it as its superclass).
RUN find /venv/lib -name "entry_points.txt" -path "*/opentelemetry_distro-*.dist-info/*" | \
    xargs sed -i \
    's/^configurator = opentelemetry\.distro:OpenTelemetryConfigurator$/otel_configurator = opentelemetry.distro:OpenTelemetryConfigurator/'

# Tell opentelemetry-instrument to use the Splunk configurator and distro.
# Without OTEL_PYTHON_DISTRO, OpenTelemetryDistro (index 0) runs before SplunkDistro.
ENV OTEL_PYTHON_CONFIGURATOR=configurator
ENV OTEL_PYTHON_DISTRO=splunk_distro
