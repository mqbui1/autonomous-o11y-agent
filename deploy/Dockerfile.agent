# Build context: autonomous-o11y-agent repo root (one level above this file)
FROM python:3.11-slim

WORKDIR /opt/agent

RUN apt-get update && apt-get install -y --no-install-recommends \
        curl \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir \
        boto3>=1.34.0 \
        openai>=1.0.0 \
        flask>=3.0.0 \
        werkzeug>=3.0.0

# Copy agent source (build context is repo root)
COPY agents/       ./agents/
COPY tools/        ./tools/
COPY providers/    ./providers/
COPY streaming/    ./streaming/
COPY approval/     ./approval/
COPY agent.py      ./
COPY agent_loop.py ./
COPY config.py     ./
COPY main.py       ./
COPY state.py      ./
COPY loop.py       ./
COPY narrator.py   ./

# State directory
RUN mkdir -p /home/agent/.o11y-agent

ENV PYTHONUNBUFFERED=1
ENV WATCH_INTERVAL=30

EXPOSE 4318

# Shell form so env vars are expanded at runtime.
# --streaming enables the OTLP receiver on :4318 (collector fans out here).
# --watch runs batch assessments every $WATCH_INTERVAL minutes alongside it.
CMD python3 main.py --streaming --watch --interval ${WATCH_INTERVAL}
