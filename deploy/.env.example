# ============================================================
# Splunk Observability Cloud — required
# ============================================================

# Access token with API + ingest scope
SPLUNK_ACCESS_TOKEN=your_access_token_here

# Your Splunk O11y realm (us0, us1, us2, eu0, ap0, etc.)
SPLUNK_REALM=us1

# Environment name — all telemetry + agent queries use this scope.
# Pick something unique so you can find it in Splunk O11y.
# Example: astronomy-shop-local
SPLUNK_ENVIRONMENT=astronomy-shop-local

# HEC token + endpoint for log forwarding (get from Settings → Data Inputs → HTTP Event Collector)
SPLUNK_HEC_TOKEN=your_hec_token_here
SPLUNK_HEC_URL=https://http-inputs-<your-org>.splunkcloud.com:443

# ============================================================
# LLM Provider for the O11y Agent — choose one
# ============================================================

# Option A: AWS Bedrock (default)
# Requires Claude model access enabled in Bedrock console
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=us-east-1

# Option B: OpenAI-compatible (uncomment to use)
# LLM_PROVIDER=openai
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ============================================================
# Agent tuning — optional
# ============================================================

# Assessment interval in minutes (default: 30)
WATCH_INTERVAL=30

# Apply detector recommendations automatically (default: false = dry-run)
AUTO_APPLY=false

# Load generator user count (default: 5)
LOCUST_USERS=5

# Astronomy Shop image version (default: latest)
DEMO_VERSION=latest
