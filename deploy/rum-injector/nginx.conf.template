server {
    listen 80;

    location / {
        proxy_pass http://frontend-proxy:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        # WebSocket support (Next.js HMR)
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 60s;

        # Tell upstream not to gzip so sub_filter can match text.
        # NOTE: this MUST be inside the location block — proxy_set_header at
        # the server level is dropped entirely once a location block defines
        # its own proxy_set_header directives (nginx does not merge/inherit
        # in that case). "identity" is honored by the Envoy frontend-proxy;
        # an empty string is not.
        proxy_set_header Accept-Encoding "identity";

        # Inject Splunk RUM snippet before </head> on every HTML page
        sub_filter_types text/html;
        sub_filter_once on;
        sub_filter '</head>' '<script src="https://cdn.signalfx.com/o11y-gdi-rum/latest/splunk-otel-web.js" crossorigin="anonymous"></script><script>SplunkRum.init({beaconEndpoint:"https://rum-ingest.${SPLUNK_REALM}.signalfx.com/v1/rum",rumAccessToken:"${SPLUNK_RUM_TOKEN}",applicationName:"astroshop",deploymentEnvironment:"${SPLUNK_ENVIRONMENT}",version:"1.0.0"});</script></head>';
    }
}
