# Builds an Ollama image with the fine-tuned o11y-agent-3b model baked in.
#
# Build from repo root:
#   docker build -f deploy/Dockerfile.ollama \
#     --build-arg GGUF_PATH=training/output/o11y-agent-3b-q4km.gguf \
#     -t o11y-agent-ollama:latest .
#
# The model is pre-loaded at build time so startup is instant for customers.
# No internet access required at runtime.

FROM ollama/ollama:latest

ARG GGUF_PATH=training/output/o11y-agent-3b-q4km.gguf
ARG MODEL_NAME=o11y-agent-3b
ARG MODELFILE_PATH=training/output/Modelfile

COPY ${GGUF_PATH} /models/${MODEL_NAME}.gguf

# IMPORTANT: copy the repo's Modelfile (has the Qwen2.5 tool-calling TEMPLATE
# block) rather than regenerating a bare 'FROM ...' file here. A template-less
# Modelfile makes Ollama fall back to a no-op '{{ .Prompt }}' template with no
# tool-call grammar, which intermittently leaks raw <tool_call>...</tool_call>
# text as plain assistant output instead of parsed tool calls (confirmed root
# cause, 2026-07-22 round 6).
COPY ${MODELFILE_PATH} /models/Modelfile
RUN sed -i "1s|.*|FROM /models/${MODEL_NAME}.gguf|" /models/Modelfile

# Pre-load the model so first inference is instant (no cold-start delay)
RUN ollama serve & \
    sleep 8 && \
    ollama create ${MODEL_NAME} -f /models/Modelfile && \
    pkill ollama || true

ENV OLLAMA_MODEL=${MODEL_NAME}

EXPOSE 11434

ENTRYPOINT ["/bin/ollama"]
CMD ["serve"]
