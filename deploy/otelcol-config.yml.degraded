# Splunk Gateway OTel Collector Config — DEGRADED STATE (demo Act 1)
# Missing: host.name stamping, deployment.environment span tag promotion
# This config intentionally omits fixes so the agent can detect the gaps.

extensions:
  health_check:
    endpoint: 0.0.0.0:13133
  http_forwarder:
    ingress:
      endpoint: 0.0.0.0:6060
    egress:
      endpoint: "https://api.${SPLUNK_REALM}.signalfx.com"
  zpages:
    endpoint: 0.0.0.0:55679

receivers:
  otlp:
    protocols:
      grpc:
        endpoint: 0.0.0.0:4317
      http:
        endpoint: 0.0.0.0:4318

  # Valkey (Redis-compatible) metrics for cart service visibility
  redis:
    endpoint: "valkey-cart:6379"
    collection_interval: 10s

  # Scrape collector's own operational metrics so health check can verify it's alive
  prometheus/internal:
    config:
      scrape_configs:
        - job_name: otelcol
          scrape_interval: 15s
          static_configs:
            - targets: ["0.0.0.0:8888"]

processors:
  batch:
    timeout: 5s
    send_batch_size: 1000

  memory_limiter:
    check_interval: 2s
    limit_mib: 200

  # DEGRADED: sf_environment not set — services appear in wrong/no environment bucket
  resource/add_environment:
    attributes:
      - action: upsert
        value: "${SPLUNK_ENVIRONMENT}"
        key: deployment.environment

  # DEGRADED: override: false — system detector won't stamp host.name when SDK omits it
  resourcedetection:
    detectors: [env, system]
    timeout: 10s
    override: false

  # DEGRADED: transform/promote_env_to_span is absent
  # deployment.environment will NOT appear as a span tag in Splunk APM

exporters:
  # Traces → Splunk APM
  otlphttp/traces:
    traces_endpoint: "https://ingest.${SPLUNK_REALM}.signalfx.com/v2/trace/otlp"
    headers:
      "X-SF-Token": "${SPLUNK_INGEST_TOKEN}"

  # Metrics → Splunk Infrastructure Monitoring
  signalfx:
    access_token: "${SPLUNK_INGEST_TOKEN}"
    realm: "${SPLUNK_REALM}"
    sync_host_metadata: false
    send_otlp_histograms: true
    timeout: 30s
    idle_conn_timeout: 60s
    http2_read_idle_timeout: 30s
    http2_ping_timeout: 10s

  splunk_hec/profiling:
    token: "${SPLUNK_INGEST_TOKEN}"
    endpoint: "https://ingest.${SPLUNK_REALM}.signalfx.com/v1/log"
    log_data_enabled: false
    profiling_data_enabled: true

  # Secondary fan-out → O11y Agent streaming receiver
  # encoding: json required — agent receiver only handles JSON, not protobuf.
  # compression: none required — Flask receiver doesn't auto-decompress gzip.
  otlphttp/agent:
    endpoint: "http://o11y-agent:4318"
    encoding: json
    compression: none
    sending_queue:
      enabled: true
      num_consumers: 2
      queue_size: 1000
    retry_on_failure:
      enabled: true
      initial_interval: 5s
      max_interval: 30s
      max_elapsed_time: 120s

service:
  telemetry:
    metrics:
      level: detailed
      address: 0.0.0.0:8888

  extensions: [health_check, http_forwarder, zpages]

  pipelines:
    traces:
      receivers: [otlp]
      processors: [memory_limiter, batch, resourcedetection, resource/add_environment]
      exporters: [otlphttp/traces, signalfx, otlphttp/agent]

    metrics:
      receivers: [otlp, redis]
      processors: [memory_limiter, batch, resourcedetection, resource/add_environment]
      exporters: [signalfx]

    logs:
      receivers: [otlp]
      processors: [memory_limiter, batch, resourcedetection]
      exporters: [splunk_hec/profiling, otlphttp/agent]

    metrics/internal:
      receivers: [prometheus/internal]
      processors: [memory_limiter, batch]
      exporters: [signalfx]
