# Splunk Observability Cloud
SPLUNK_REALM=us1
SPLUNK_ACCESS_TOKEN=your-api-token-here
SPLUNK_ENVIRONMENT=production

# AWS / Bedrock (for LLM)
AWS_DEFAULT_REGION=us-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Optional: override default sibling-directory paths to each tool project
# PROVISIONER_PATH=../auto-detector-provisioner
# GOVERNANCE_PATH=../o11y-usage-governance
# ANALYZER_PATH=../o11y-instrumentation-analyzer
# HEALTH_CHECK_PATH=../splunk-o11y-health-check

# Optional: Bedrock model override
# BEDROCK_MODEL_ID=arn:aws:bedrock:us-west-2:387769110234:application-inference-profile/fky19kpnw2m7

# Optional: subprocess timeout per tool call in seconds (default: 300)
# TOOL_TIMEOUT=300

# ── Performance specialist: source code access ────────────────────────────────
# Option A: mount your source repo directory
# SOURCE_ROOT=/src                      # inside container (docker-compose volume mount)
# SOURCE_ROOT=/Users/you/code/myrepo   # local dev

# Option B: GitHub API (fetches file contents on demand)
# GITHUB_TOKEN=ghp_...
# GITHUB_REPO=myorg/myrepo
# GITHUB_BRANCH=main

# Neither set → profiling-only mode (file:line recommendations, no code diffs)
